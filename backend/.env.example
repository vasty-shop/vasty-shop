# =====================================================
# VASTY SHOP BACKEND CONFIGURATION
# =====================================================
# Copy this file to .env and update with your values
# =====================================================

# Application
NODE_ENV=development
PORT=4005
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:4007

# =====================================================
# DATABASE (PostgreSQL)
# =====================================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=vasty_shop_dev
DATABASE_USER=postgres
DATABASE_PASSWORD=your_db_password

# =====================================================
# REDIS
# =====================================================
REDIS_HOST=localhost
REDIS_PORT=6379

# =====================================================
# CLOUDFLARE R2 STORAGE (S3-compatible)
# =====================================================
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=vasty-shop-dev
R2_PUBLIC_URL=https://cdn.vasty.shop

# =====================================================
# JWT
# =====================================================
JWT_SECRET=your_jwt_secret_key_min32chars_change_in_production
JWT_EXPIRATION=7d

# =====================================================
# STRIPE PAYMENTS
# =====================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Connect (Vendor Payouts)
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_your_connect_webhook_secret
STRIPE_PLATFORM_FEE_PERCENT=1

# =====================================================
# OAUTH
# =====================================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4005/api/v1/auth/oauth/google/callback

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:4005/api/v1/auth/oauth/github/callback

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# =====================================================
# EMAIL (SMTP)
# =====================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@vasty.shop
EMAIL_FROM_NAME=Vasty Shop

# =====================================================
# WEBSOCKET
# =====================================================
WS_PORT=3002
WS_CORS_ORIGIN=http://localhost:4007,http://localhost:3000

# =====================================================
# APP SETTINGS
# =====================================================
DEFAULT_CURRENCY=USD
DEFAULT_LOCALE=en-US
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_WEBSOCKET_NOTIFICATIONS=true
ENABLE_PUSH_NOTIFICATIONS=false
