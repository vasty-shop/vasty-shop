# =====================================================
# VASTY SHOP BACKEND CONFIGURATION
# =====================================================
# Copy this file to .env and update with your values
# =====================================================

# Application
NODE_ENV=development
PORT=4005
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:5186

# =====================================================
# DATABASE (PostgreSQL)
# =====================================================
# Use "postgres" as host when running with Docker Compose
# Use "localhost" when running locally without Docker
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=vasty_shop_dev
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# =====================================================
# REDIS
# =====================================================
# Use "redis" as host when running with Docker Compose
# Use "localhost" when running locally without Docker
REDIS_HOST=redis
REDIS_PORT=6379

# =====================================================
# FILE STORAGE
# =====================================================
# Pick a provider. local-fs needs zero setup and is the recommended
# starting point for dev. See docs/providers/storage.md for the full
# comparison and per-provider env vars.
#
# Valid values:
#   local-fs | s3 | r2 | minio | b2 | gcs | azure | none

STORAGE_PROVIDER=local-fs

# --- local-fs (default, zero infra) ---
LOCAL_FS_PATH=./data/uploads
LOCAL_FS_PUBLIC_URL=/uploads
LOCAL_FS_SIGNING_KEY=change_me_to_a_long_random_string

# --- S3-compatible (s3 / r2 / minio / b2) ---
STORAGE_BUCKET=vasty-shop-dev
STORAGE_REGION=auto
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_ENDPOINT=
STORAGE_PUBLIC_URL=
STORAGE_FORCE_PATH_STYLE=false

# --- Google Cloud Storage (gcs, optional dep) ---
GCS_PROJECT_ID=
GCS_KEY_FILE=

# --- Azure Blob Storage (azure, optional dep) ---
AZURE_STORAGE_CONNECTION_STRING=

# Legacy R2_* env vars — still honored for backwards compatibility if
# STORAGE_PROVIDER is unset. Plan to migrate to STORAGE_* above.
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=vasty-shop-dev
R2_PUBLIC_URL=https://cdn.vasty.shop

# =====================================================
# JWT
# =====================================================
JWT_SECRET=your_jwt_secret_key_min32chars_change_in_production
JWT_EXPIRATION=7d

# =====================================================
# STRIPE PAYMENTS
# =====================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Connect (Vendor Payouts)
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_your_connect_webhook_secret
STRIPE_PLATFORM_FEE_PERCENT=1

# =====================================================
# OAUTH
# =====================================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4005/api/v1/auth/oauth/google/callback

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:4005/api/v1/auth/oauth/github/callback

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# =====================================================
# EMAIL
# =====================================================
# Pick a provider. See backend/docs/providers/email.md for the full
# comparison and per-provider env vars.
#
# Valid values: smtp | resend | sendgrid | postmark | ses | mailgun | none

EMAIL_PROVIDER=smtp
EMAIL_FROM=Vasty Shop <noreply@vasty.shop>
EMAIL_REPLY_TO=

# --- SMTP (default, works with Gmail/Mailtrap/Postfix/etc) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# --- Resend (https://resend.com) ---
RESEND_API_KEY=

# --- SendGrid (https://sendgrid.com) ---
SENDGRID_API_KEY=

# --- Postmark (https://postmarkapp.com) ---
POSTMARK_SERVER_TOKEN=

# --- AWS SES (optional dep @aws-sdk/client-ses) ---
SES_REGION=us-east-1
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=

# --- Mailgun (https://www.mailgun.com) ---
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_REGION=us

# Legacy, still read by database/email-helpers.ts:
EMAIL_FROM_NAME=Vasty Shop

# =====================================================
# WEBSOCKET
# =====================================================
WS_PORT=3002
WS_CORS_ORIGIN=http://localhost:5186,http://localhost:3000

# =====================================================
# APP SETTINGS
# =====================================================
DEFAULT_CURRENCY=USD
DEFAULT_LOCALE=en-US
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_WEBSOCKET_NOTIFICATIONS=true
ENABLE_PUSH_NOTIFICATIONS=false

# =====================================================
# SMS
# =====================================================
SMS_PROVIDER=none
SMS_FROM=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
MESSAGEBIRD_API_KEY=
VONAGE_API_KEY=
VONAGE_API_SECRET=
AWS_SNS_REGION=us-east-1
AWS_SNS_ACCESS_KEY_ID=
AWS_SNS_SECRET_ACCESS_KEY=
TEXTBEE_API_KEY=
TEXTBEE_DEVICE_ID=
LOCAL_SMS_URL=
LOCAL_SMS_METHOD=POST
LOCAL_SMS_AUTH_HEADER=
LOCAL_SMS_BODY_TEMPLATE={"to":"{{to}}","text":"{{text}}"}
LOCAL_SMS_CONTENT_TYPE=application/json

# =====================================================
# SEARCH
# =====================================================
SEARCH_PROVIDER=pg-trgm
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=
TYPESENSE_URL=http://localhost:8108
TYPESENSE_API_KEY=

# =====================================================
# AI / LLM
# =====================================================
AI_PROVIDER=none
AI_MODEL=
AI_VISION_MODEL=
AI_EMBEDDING_MODEL=
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
GROQ_API_KEY=
GROQ_BASE_URL=

# =====================================================
# MAPS / GEOCODING
# =====================================================
MAPS_PROVIDER=osm-leaflet
MAPS_DEFAULT_LAT=23.8103
MAPS_DEFAULT_LNG=90.4125
MAPS_DEFAULT_ZOOM=12
NOMINATIM_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=vasty-shop/1.0
OSM_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_BROWSER_KEY=
MAPBOX_TOKEN=
MAPBOX_STYLE=mapbox://styles/mapbox/streets-v12
MAPTILER_API_KEY=

# =====================================================
# TAX CALCULATION
# =====================================================
TAX_PROVIDER=manual-rules
TAXJAR_API_KEY=
TAXJAR_SANDBOX=false

# =====================================================
# PUSH NOTIFICATIONS
# =====================================================
PUSH_PROVIDER=none
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_SERVICE_ACCOUNT_FILE=
FIREBASE_WEB_CONFIG=
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=
EXPO_ACCESS_TOKEN=

# =====================================================
# SHIPPING / LOGISTICS
# =====================================================
# Valid values: manual-zones | shipengine | easypost | shippo | pathao | none

SHIPPING_PROVIDER=manual-zones
SHIPENGINE_API_KEY=
EASYPOST_API_KEY=
SHIPPO_API_KEY=
PATHAO_BASE_URL=https://courier-api-sandbox.pathao.com
PATHAO_CLIENT_ID=
PATHAO_CLIENT_SECRET=
PATHAO_USERNAME=
PATHAO_PASSWORD=
PATHAO_STORE_ID=
