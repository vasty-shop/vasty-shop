# Fluxez Shop Configuration
# Copy this file to .env and update with your values

SHOP_ID=your-shop-id-here
APP_NAME=you-app-name
PACKAGE_NAME=com.you-company-name.product-name
MIN_SDK= 26
TERGET_SDK= 36
VERSION_CODE=1
VERSION_NAME= "1.0.0"

# ============================================
# STRIPE CONFIGURATION
# ============================================
# Publishable key for Stripe (client-side)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Merchant identifier for Apple Pay (optional)
STRIPE_MERCHANT_ID=merchant.com.your-domain